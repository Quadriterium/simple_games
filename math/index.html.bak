<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Exercices de Math</title>
    <link rel="stylesheet" href="../style.css">
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="app">
        <!-- Game Switcher (tabs) -->
        <div id="game-switcher">
            <button class="game-tab active" data-game="multiply">✖️ Multiplications</button>
            <button class="game-tab" data-game="challenge">🏆 Challenge</button>
            <button class="game-tab" data-game="leaderboard">🏅 Classement</button>
        </div>

        <!-- ===== Multiplication Game ===== -->
        <div id="game-multiply" class="game-panel">
            <h1>🧮 Exercices de Math</h1>
            <p class="rules">Résous les multiplications le plus vite possible !<br>Choisis ton niveau de difficulté et c'est parti !</p>

            <button class="menu-toggle" aria-expanded="true">⚙️ Options <span class="menu-arrow">▲</span></button>
            <div class="menu-collapsible">
                <div id="math-difficulty">
                    <button class="mathdiff-btn active" data-level="easy">🟢 Facile</button>
                    <button class="mathdiff-btn" data-level="medium">🟡 Moyen</button>
                    <button class="mathdiff-btn" data-level="hard">🔴 Difficile</button>
                </div>
            </div>

            <div id="score-bar">
                <span id="score-correct">✅ <span id="correct-count">0</span></span>
                <span id="score-wrong">❌ <span id="wrong-count">0</span></span>
                <span id="score-streak">🔥 Série : <span id="streak-count">0</span></span>
            </div>

            <div id="problem-card">
                <div id="problem-text">
                    <span id="operand-a"></span>
                    <span class="operator">×</span>
                    <span id="operand-b"></span>
                    <span class="operator">=</span>
                    <span id="answer-placeholder">?</span>
                </div>
            </div>

            <form id="answer-form">
                <input
                    type="text"
                    id="answer-input"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    autocomplete="off"
                    placeholder="Ta réponse..."
                    autofocus
                >
                <button type="submit" id="submit-btn">Valider ✅</button>
            </form>

            <div id="math-message" class="hidden"></div>
        </div>

        <!-- ===== Challenge Mode ===== -->
        <div id="game-challenge" class="game-panel hidden">
            <h1>🏆 Challenge</h1>
            <p class="rules">Choisis ton défi et montre ce que tu sais faire !</p>

            <button class="menu-toggle" aria-expanded="true">⚙️ Options <span class="menu-arrow">▲</span></button>
            <div class="menu-collapsible">
                <div id="challenge-difficulty">
                    <button class="mathdiff-btn active" data-level="easy">🟢 Facile</button>
                    <button class="mathdiff-btn" data-level="medium">🟡 Moyen</button>
                    <button class="mathdiff-btn" data-level="hard">🔴 Difficile</button>
                </div>
                <div id="challenge-mode-select">
                    <button class="challenge-mode-btn active" data-mode="100">💯 100 calculs</button>
                    <button class="challenge-mode-btn" data-mode="timer">⏱️ 1 minute</button>
                </div>
            </div>

            <!-- Before start -->
            <div id="challenge-start-screen">
                <div id="challenge-description" class="challenge-desc-card">
                    <p id="challenge-desc-text">Fais 100 multiplications le plus vite possible !</p>
                </div>
                <button id="challenge-start-btn">🚀 C'est parti !</button>
            </div>

            <!-- During challenge -->
            <div id="challenge-play-screen" class="hidden">
                <div id="challenge-status-bar">
                    <span id="challenge-progress">📝 0 / 100</span>
                    <span id="challenge-timer">⏱️ 00:00</span>
                    <span id="challenge-errors">❌ 0</span>
                </div>

                <div id="challenge-problem-card" class="problem-card-style">
                    <div class="problem-text-style">
                        <span id="challenge-operand-a"></span>
                        <span class="operator">×</span>
                        <span id="challenge-operand-b"></span>
                        <span class="operator">=</span>
                        <span class="answer-placeholder-style">?</span>
                    </div>
                </div>

                <form id="challenge-answer-form">
                    <input
                        type="text"
                        id="challenge-answer-input"
                        inputmode="numeric"
                        pattern="[0-9]*"
                        autocomplete="off"
                        placeholder="Ta réponse..."
                    >
                    <button type="submit" id="challenge-submit-btn">Valider ✅</button>
                </form>

                <div id="challenge-feedback" class="hidden"></div>
            </div>

            <!-- Results -->
            <div id="challenge-result-screen" class="hidden">
                <div id="challenge-result-card">
                    <h2 id="challenge-result-title"></h2>
                    <div id="challenge-result-stats"></div>
                    <p id="challenge-result-message"></p>
                </div>
                <div id="save-score-section">
                    <p id="save-score-prompt">Enregistrer ton score dans le classement ?</p>
                    <form id="save-score-form">
                        <input
                            type="text"
                            id="save-score-name"
                            maxlength="30"
                            autocomplete="off"
                            placeholder="Ton prénom..."
                        >
                        <button type="submit" id="save-score-btn">💾 Enregistrer</button>
                    </form>
                    <p id="save-score-status" class="hidden"></p>
                </div>
                <button id="challenge-retry-btn">🔄 Recommencer</button>
            </div>
        </div>

        <!-- ===== Leaderboard ===== -->
        <div id="game-leaderboard" class="game-panel hidden">
            <h1>🏅 Classement</h1>
            <p class="rules">Les meilleurs scores de tous les joueurs !</p>

            <div id="lb-filters">
                <div id="lb-mode-select">
                    <button class="lb-mode-btn active" data-mode="100">💯 100 calculs</button>
                    <button class="lb-mode-btn" data-mode="timer">⏱️ 1 minute</button>
                </div>
                <div id="lb-level-select">
                    <button class="lb-level-btn active" data-level="easy">🟢 Facile</button>
                    <button class="lb-level-btn" data-level="medium">🟡 Moyen</button>
                    <button class="lb-level-btn" data-level="hard">🔴 Difficile</button>
                </div>
            </div>

            <div id="lb-table-container">
                <table id="lb-table">
                    <thead>
                        <tr id="lb-header"></tr>
                    </thead>
                    <tbody id="lb-body"></tbody>
                </table>
                <p id="lb-empty" class="hidden">Aucun score pour le moment. Sois le premier ! 🚀</p>
                <p id="lb-loading" class="hidden">Chargement...</p>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
